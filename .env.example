# Copy this file to ".env" and set your own values.
# The .env file is gitignored so real secrets never reach the public repo.

# Password the staff use to log in to the dashboard.
# Wrap the value in quotes if it contains a # so it isn't read as a comment.
STAFF_PASSWORD="your-staff-password-here"

# Stripe secret key. Leave this out to use the built-in demo checkout.
# To take real payments, paste your Stripe secret key here. Use a TEST key
# (starts with sk underscore test) while developing. Get one from
# dashboard.stripe.com.
# STRIPE_SECRET_KEY="<your-stripe-test-key>"
